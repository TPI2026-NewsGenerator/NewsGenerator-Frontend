                        d="M3.166 5.128a.5.5 0 0 1 .706.037L8 9.752l4.128-4.587a.5.5 0 1 1 .743.669l-4.5 5a.5.5 0 0 1-.744 0l-4.5-5a.5.5 0 0 1 .037-.706z"
                      />
                    </svg>
                  </div>
                </div>
              </div>
              <div
                class="rs-picker-textbox"
              >
                <div
                  class="rs-picker-tag-list"
                  id="rs-_r_6_-describe"
                  role="listbox"
                >
                  <div
