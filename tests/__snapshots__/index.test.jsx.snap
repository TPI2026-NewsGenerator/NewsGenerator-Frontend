                      id="rs-_r_6_-describe"
                    >
                      Select news category
                    </span>
                  </div>
                  <div
                    class="rs-picker-toggle-indicator rs-stack-item rs-box-_r_b_"
                    data-rs="box"
                  >
                    <svg
                      aria-hidden="true"
                      aria-label="arrow down line"
                      class="rs-picker-caret-icon rs-icon rs-icon"
                      data-category="direction"
                      data-testid="caret"
                      fill="currentColor"
                      focusable="false"
                      height="1em"
                      viewBox="0 0 16 16"
